# Database
DATABASE_URL="postgresql://stewie:stewiepassword@localhost:5432/stewiepay"

# Auth
# Required in production; never leave default
JWT_SECRET="changeme-dev-secret"
JWT_EXPIRES_IN="15m"
BCRYPT_SALT_ROUNDS="10"
REFRESH_TOKEN_TTL_DAYS="30"
BCRYPT_SALT_ROUNDS="10"
REFRESH_TOKEN_DAYS="14"

# Issuer / PSP placeholders
ISSUER_PROVIDER="dummy"
ISSUER_API_KEY="issuer-api-key"
ISSUER_BASE_URL="https://issuer-sandbox.example.com"
ISSUER_WEBHOOK_SECRET="issuer-webhook-secret"
PSP_PROVIDER="dummy"
PSP_API_KEY="psp-api-key"
PSP_BASE_URL="https://psp-sandbox.example.com"
PSP_WEBHOOK_SECRET="psp-webhook-secret"

# Chapa (PSP) - set PSP_PROVIDER="chapa"
# PSP_API_KEY should be your CHAPA secret key
CHAPA_CALLBACK_URL="https://your-backend.com/api/webhooks/chapa"
CHAPA_RETURN_URL="https://your-frontend.com/topup/return"
CHAPA_CUSTOMIZATION_TITLE="StewiePay Top Up"
CHAPA_CUSTOMIZATION_DESCRIPTION="Complete your top up securely"
CHAPA_DEFAULT_EMAIL="pay@stewiepay.com"
CHAPA_WEBHOOK_SECRET="your-chapa-webhook-secret"
CHAPA_VERIFY_ON_WEBHOOK="true"
# Optional issuer settlement event flow:
# issuer webhooks can emit funding.pending / funding.loaded / funding.failed
# with funding.topUpReference to reconcile "funded" vs "card loaded" states.

# Cloudinary (Image Storage)
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email Service
# Choose provider: 'smtp', 'gmail', or 'sendgrid'
EMAIL_PROVIDER="smtp"
EMAIL_FROM="noreply@stewiepay.com"

# SMTP Configuration (generic SMTP or Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Gmail Configuration (alternative to SMTP)
# GMAIL_USER="your-email@gmail.com"
# GMAIL_APP_PASSWORD="your-app-password"

# SendGrid Configuration (alternative to SMTP)
# SENDGRID_API_KEY="your-sendgrid-api-key"

# Frontend URL (for password reset links)
FRONTEND_URL="http://localhost:8081"
# Public backend URL used in verification emails as fallback.
# If signup request comes from a reachable host/IP, backend now auto-uses that host for email links.
BACKEND_PUBLIC_URL="http://localhost:3000"

# Sentry (Backend)
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"

# KYC enforcement for financial actions (cards, topups, spends)
# Recommended: true in staging/production
ENFORCE_KYC_FOR_PAYMENTS="false"
# Optional phased rollout:
# - When true, users with kycStatus=SUBMITTED can use limited topup/spend flows.
# - Card creation still requires VERIFIED.
KYC_ALLOW_SUBMITTED_WITH_LIMITS="false"
KYC_LIMITED_TOPUP_PER_TXN="5000"
KYC_LIMITED_TOPUP_DAILY="20000"
KYC_LIMITED_TOPUP_MONTHLY="100000"
KYC_LIMITED_SPEND_PER_TXN="3000"
KYC_LIMITED_SPEND_DAILY="10000"
KYC_LIMITED_SPEND_MONTHLY="50000"

# KYC automation (no manual review required)
# When enabled, submit flow auto-decides VERIFIED/REJECTED and logs review events.
KYC_AUTO_REVIEW_ENABLED="true"
# internal = built-in rules, http = call external auto-review provider endpoint
KYC_AUTO_REVIEW_PROVIDER="internal"
# Modes:
# - approve: approve valid uploads by default, reject obviously invalid images.
# - strict: adds country allowlist checks.
KYC_AUTO_REVIEW_MODE="approve"
KYC_AUTOMATION_REVIEWER_EMAIL="kyc-system@stewiepay.local"
KYC_AUTOMATION_REVIEWER_NAME="StewiePay KYC Automation"
KYC_AUTO_REVIEW_MIN_IMAGE_BYTES="8000"
KYC_AUTO_REVIEW_MAX_IMAGE_BYTES="8000000"
# Used only in strict mode
KYC_AUTO_REVIEW_ALLOWED_COUNTRIES="ethiopia,et,canada,ca"
# Used only when KYC_AUTO_REVIEW_PROVIDER="http"
KYC_AUTO_REVIEW_HTTP_URL=""
KYC_AUTO_REVIEW_HTTP_SECRET=""
# Behavior when HTTP provider fails:
# - fallback: use internal decision rules
# - reject: reject KYC immediately if provider is unavailable
KYC_AUTO_REVIEW_HTTP_FAIL_MODE="fallback"

# Integration readiness gate
# true in production by default (can be set explicitly in staging)
STRICT_INTEGRATION_CONFIG="false"
# Recommended overrides:
# - staging: STRICT_INTEGRATION_CONFIG="true"
# - production: STRICT_INTEGRATION_CONFIG="true"

# CORS allowlist (comma-separated origins). If empty, safe localhost defaults are used.
CORS_ORIGIN_ALLOWLIST="http://localhost:3000,http://localhost:3001,http://localhost:8081"
# Recommended staging/production values should contain only real app/admin origins.
# Allow ngrok origins by hostname suffix (useful for simulator/device testing)
CORS_ALLOW_NGROK="true"
CORS_NGROK_SUFFIXES=".ngrok-free.app,.ngrok-free.dev"

