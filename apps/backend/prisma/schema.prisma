generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  INDIVIDUAL
  BUSINESS
  ADMIN
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum CardStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum CardType {
  PERMANENT
  BURNER
  MERCHANT_LOCKED
  SUBSCRIPTION_ONLY
  ADS_ONLY
}

enum TransactionStatus {
  AUTHORIZED
  SETTLED
  DECLINED
}

enum TopUpStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TopUpFundingState {
  PSP_PENDING
  PSP_CONFIRMED
  ISSUER_PENDING
  CARD_LOADED
  FAILED
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  avatarUrl String?  // Profile photo URL
  role      UserRole @default(INDIVIDUAL)
  passwordHash String
  emailVerified Boolean @default(false)
  emailVerifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedOrganizations Organization[] @relation("OrganizationOwner")
  memberships        OrganizationMember[]
  cards              Card[]           @relation("UserCards")
  topUps             TopUp[]
  refreshTokens      RefreshToken[]
  sentOrganizationInvites     OrganizationInvite[] @relation("OrgInviteInvitedBy")
  acceptedOrganizationInvites OrganizationInvite[] @relation("OrgInviteAcceptedBy")

  // Push notifications
  pushToken          String?
  notificationPreferences Json? // { transactions: true, limits: true, subscriptions: true, cardStatus: true }

  // KYC
  kycStatus          KycStatus @default(PENDING)
  kycSubmittedAt     DateTime?
  kycVerifiedAt      DateTime?
  kycRejectionReason String?
  kycDocuments       Json?
  kycReviews         KycReviewEvent[] @relation("KycSubject")
  kycReviewsDone     KycReviewEvent[] @relation("KycReviewer")

  // Budgets
  budgets            Budget[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User     @relation("OrganizationOwner", fields: [ownerId], references: [id])

  members OrganizationMember[]
  cards   Card[] @relation("OrgCards")
  topUps  TopUp[]
  invites OrganizationInvite[]
}

model OrganizationMember {
  id        String   @id @default(uuid())
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now())

  userId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model OrganizationInvite {
  id             String   @id @default(uuid())
  email          String
  role           OrgRole  @default(MEMBER)
  tokenHash      String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  acceptedAt     DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  invitedById    String
  invitedBy      User @relation("OrgInviteInvitedBy", fields: [invitedById], references: [id])

  acceptedById   String?
  acceptedBy     User? @relation("OrgInviteAcceptedBy", fields: [acceptedById], references: [id])

  @@unique([organizationId, email])
}

model Card {
  id           String     @id @default(uuid())
  issuerCardId String
  status       CardStatus @default(ACTIVE)
  type         CardType   @default(PERMANENT)
  limitDaily   Int?
  limitMonthly Int?
  limitPerTxn  Int?
  currency     String     @default("ETB")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Merchant locks
  blockedCategories String[] @default([]) // MCC codes to block
  allowedCategories String[] @default([]) // MCC codes to allow (whitelist mode)
  blockedMerchants  String[] @default([]) // Merchant names/IDs to block
  allowedMerchants  String[] @default([]) // Merchant names/IDs to allow (whitelist mode)
  merchantLockMode  String?  // "BLOCK" or "ALLOW" - null means no merchant locks

  // Time window controls
  timeWindowEnabled Boolean  @default(false)
  timeWindowConfig  String? // JSON: { daysOfWeek: [1,2,3,4,5], startTime: "09:00", endTime: "17:00", timezone: "Africa/Addis_Ababa" }

  ownerUserId String?
  ownerOrgId  String?

  ownerUser User?         @relation("UserCards", fields: [ownerUserId], references: [id])
  ownerOrg  Organization? @relation("OrgCards", fields: [ownerOrgId], references: [id])

  transactions Transaction[]
  subscriptions Subscription[]
}

model Transaction {
  id           String            @id @default(uuid())
  amount       Int
  currency     String
  merchantName String
  mcc          String?
  category     String?
  timestamp    DateTime
  status       TransactionStatus

  cardId String
  card   Card @relation(fields: [cardId], references: [id])

  @@index([cardId, timestamp])
  @@index([cardId, status, timestamp])
}

model TopUp {
  id                    String            @id @default(uuid())
  provider              String
  reference             String
  amount                Int
  currency              String
  status                TopUpStatus       @default(PENDING)
  fundingState          TopUpFundingState @default(PSP_PENDING)
  pspCompletedAt        DateTime?
  issuerLoadedAt        DateTime?
  settlementFailureReason String?
  createdAt             DateTime          @default(now())
  userId                String?
  orgId                 String?

  user User?         @relation(fields: [userId], references: [id])
  org  Organization? @relation(fields: [orgId], references: [id])
  settlementEvents FundingSettlementEvent[]

  @@unique([reference])
  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@index([status, createdAt])
  @@index([fundingState, createdAt])
}

model FundingSettlementEvent {
  id          String   @id @default(uuid())
  topUpId     String
  source      String
  eventType   String
  fromState   TopUpFundingState?
  toState     TopUpFundingState
  message     String?
  payload     Json?
  createdAt   DateTime @default(now())

  topUp TopUp @relation(fields: [topUpId], references: [id], onDelete: Cascade)

  @@index([topUpId, createdAt])
  @@index([source, createdAt])
}

model Subscription {
  id                 String   @id @default(uuid())
  merchant           String
  amountHint         Int?
  currency           String   @default("ETB")
  nextExpectedCharge DateTime?
  lastChargeAt       DateTime?

  cardId String
  card   Card @relation(fields: [cardId], references: [id])
}

model Budget {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String   // e.g., "Food & Drink", "Shopping"
  amount    Int      // Budget amount in cents/smallest currency unit
  period    String   @default("monthly") // "monthly" or "weekly"
  currency  String   @default("ETB")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, period])
}

model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String
  userId      String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model WebhookLog {
  id        String   @id @default(uuid())
  webhookId String
  source    String
  eventType String
  success   Boolean
  createdAt DateTime @default(now())

  @@unique([webhookId, source])
  @@index([webhookId, source])
}

model WebhookJob {
  id           String   @id @default(uuid())
  source       String
  webhookId    String
  payload      Json
  signature    String?
  status       String   @default("PENDING")
  attemptCount Int      @default(0)
  lastError    String?
  nextAttemptAt DateTime @default(now())
  lockedAt     DateTime?
  processedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([source, webhookId])
  @@index([status, nextAttemptAt])
}

model KycReviewEvent {
  id                String   @id @default(uuid())
  userId            String
  reviewerId        String
  previousStatus    KycStatus
  newStatus         KycStatus
  rejectionReason   String?
  reviewNote        String?
  reviewerIp        String?
  reviewerUserAgent String?
  createdAt         DateTime @default(now())

  user     User @relation("KycSubject", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User @relation("KycReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([reviewerId, createdAt])
}

